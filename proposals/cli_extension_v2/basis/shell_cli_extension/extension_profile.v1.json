{
  "artifact_type": "extension_profile",
  "artifact_version": "v1",
  "profile_id": "shell_cli_extension_profile",
  "title": "Shell / CLI Semantic Extension Profile",
  "status": "draft",
  "base_model_refs": [
    "/home/_404/Downloads/metadata/canonical_semantic_model.schema.json",
    "/home/_404/Downloads/metadata/projection_artifact_manifest.schema.json"
  ],
