      },
      {
        "backend": "shellspec",
        "projection_role": "verification_consumer",
        "canonical_target_kind": "other"
      }
    ]
  },
  "constraint_layer": {
    "schema_ref": "proposals/shell_cli_extension/extension_constraints.schema.json",
    "example_ref": "proposals/shell_cli_extension/extension_constraints.example.json",
