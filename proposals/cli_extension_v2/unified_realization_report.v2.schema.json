{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "unified_realization_report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "document_type",
    "schema_version",
    "status",
    "payload_path",
    "primary_operator_surface",
    "realized_count",
    "targets",
    "backend_reports"
  ],
  "properties": {
    "document_type": {
      "const": "realization_report"
    },
    "schema_version": {
      "const": "v2"
    },
    "status": {
      "type": "string"
    },
    "payload_path": {
      "type": "string"
    },
    "primary_operator_surface": {
      "type": "string"
    },
    "realized_count": {
      "type": "integer",
      "minimum": 0
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_id",
          "backend",
          "adapter_family",
          "projection_role",
          "artifact_kind",
          "repo_path",
          "output_path",
          "source_project_root",
          "semantic_inputs",
          "generated_by"
        ],
        "properties": {
          "target_id": { "type": "string" },
          "backend": { "type": "string" },
          "adapter_family": { "type": "string" },
          "projection_role": { "type": "string" },
          "artifact_kind": { "type": "string" },
          "repo_path": { "type": "string" },
          "output_path": { "type": "string" },
          "source_project_root": { "type": "string" },
          "upstream_deterministic_input": { "type": "string" },
          "semantic_inputs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "generated_by": { "type": "string" }
        }
      }
    },
    "backend_reports": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    }
  }
}
