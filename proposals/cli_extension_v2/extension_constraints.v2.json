{
  "document_type": "cli_extension_constraints",
  "constraint_id": "cli_extension_constraints_v2",
  "version": "0.2.0",
  "base_model_refs": [
    "/home/_404/Downloads/metadata/canonical_semantic_model.schema.json",
    "/home/_404/Downloads/metadata/projection_artifact_manifest.schema.json"
  ],
  "lineage": {
    "replaces_constraint_namespace": "shell_cli_role",
    "new_constraint_namespace": "cli_role",
    "runtime_assets_remain_projection_only": true
  },
  "object_role_constraints": [
    {
      "cli_role": "command_surface",
      "allowed_object_kind": "artifact_target",
      "required_attributes": [
        "command_path",
        "handler_id",
        "entry_surface"
      ]
    },
    {
      "cli_role": "parameter_surface",
      "allowed_object_kind": "other",
      "required_attributes": [
        "parameter_kind",
        "command_ref"
      ]
    },
    {
      "cli_role": "environment_binding",
      "allowed_object_kind": "other",
      "required_attributes": [
        "env_name"
      ]
    },
    {
      "cli_role": "dependency_requirement",
      "allowed_object_kind": "other",
      "required_attributes": [
        "dependency_name"
      ]
    },
    {
      "cli_role": "usage_example",
      "allowed_object_kind": "other",
      "required_attributes": [
        "command_line"
      ]
    },
    {
      "cli_role": "output_contract",
      "allowed_object_kind": "policy",
      "required_attributes": [
        "output_mode"
      ]
    },
    {
      "cli_role": "verification_expectation",
      "allowed_object_kind": "other",
      "required_attributes": [
        "expectation_kind"
      ]
    }
  ],
  "relation_constraints": [
    {
      "relation_kind": "contains",
      "usage": "command_contains_parameter_or_example"
    },
    {
      "relation_kind": "defines",
      "usage": "policy_defines_output_contract"
    },
    {
      "relation_kind": "supports",
      "usage": "verification_or_dependency_supports_command_surface"
    },
    {
      "relation_kind": "references",
      "usage": "command_references_env_or_dependency"
    },
    {
      "relation_kind": "projects_to",
      "usage": "cli_semantics_project_to_runtime_adapter_artifacts"
    }
  ],
  "projection_constraints": {
    "shell_implementation_targets": [
      {
        "backend": "bashly",
        "projection_role": "implementation_target",
        "allowed_target_kind": "config_projection"
      },
      {
        "backend": "argc",
        "projection_role": "implementation_target",
        "allowed_target_kind": "config_projection"
      },
      {
        "backend": "argbash",
        "projection_role": "implementation_target",
        "allowed_target_kind": "config_projection"
      }
    ],
    "python_implementation_targets": [
      {
        "backend": "jsonargparse",
        "projection_role": "implementation_target",
        "allowed_target_kind": "codegen_input"
      }
    ],
    "shell_verification_targets": [
      {
        "backend": "bats",
        "projection_role": "verification_consumer",
        "allowed_target_kind": "other"
      },
      {
        "backend": "shellspec",
        "projection_role": "verification_consumer",
        "allowed_target_kind": "other"
      }
    ],
    "python_verification_targets": [
      {
        "backend": "pytest",
        "projection_role": "verification_consumer",
        "allowed_target_kind": "other"
      }
    ]
  },
  "notes": [
    "This runtime-neutral constraint layer preserves the base metadata model and generalizes the role namespace from shell_cli_role to cli_role.",
    "The approved Bashly+Bats shell slice remains valid as a v1 slice and is not retroactively invalidated by this v2 constraint layer."
  ]
}
