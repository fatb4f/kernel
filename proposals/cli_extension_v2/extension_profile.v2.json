{
  "artifact_type": "extension_profile",
  "artifact_version": "v2",
  "profile_id": "cli_extension_profile_v2",
  "title": "Runtime-Neutral CLI Semantic Extension Profile",
  "status": "draft",
  "base_model_refs": [
    "proposals/cli_extension_v2/basis/metadata/canonical_semantic_model.schema.json",
    "proposals/cli_extension_v2/basis/metadata/projection_artifact_manifest.schema.json"
  ],
  "lineage": {
    "extends": "canonical_semantic_model",
    "does_not_introduce_parallel_authority_model": true,
    "runtime_assets_remain_projection_only": true
  },
  "semantic_profile": {
    "object_strategy": "use_existing_object_kinds_with_cli_role_attributes",
    "supported_object_patterns": [
      {
        "object_kind": "artifact_target",
        "cli_role": "command_surface",
        "required_attributes": [
          "command_path",
          "handler_id",
          "summary"
        ]
      },
      {
        "object_kind": "other",
        "cli_role": "parameter_surface",
        "required_attributes": [
          "parameter_kind",
          "command_ref"
        ]
      },
      {
        "object_kind": "other",
        "cli_role": "environment_binding",
        "required_attributes": [
          "env_name"
        ]
      },
      {
        "object_kind": "other",
        "cli_role": "dependency_requirement",
        "required_attributes": [
          "dependency_name"
        ]
      },
      {
        "object_kind": "other",
        "cli_role": "usage_example",
        "required_attributes": [
          "command_line"
        ]
      },
      {
        "object_kind": "policy",
        "cli_role": "output_contract",
        "required_attributes": [
          "output_mode"
        ]
      },
      {
        "object_kind": "other",
        "cli_role": "verification_expectation",
        "required_attributes": [
          "expectation_kind"
        ]
      }
    ],
    "relation_profile": [
      {
        "relation_kind": "contains",
        "usage": "command_contains_parameter_or_example"
      },
      {
        "relation_kind": "defines",
        "usage": "policy_defines_output_or_validation_contract"
      },
      {
        "relation_kind": "supports",
        "usage": "dependency_or_verification_supports_command_surface"
      },
      {
        "relation_kind": "projects_to",
        "usage": "semantic_cli_targets_project_to_runtime_adapter_artifacts"
      },
      {
        "relation_kind": "references",
        "usage": "command_or_parameter_references_env_or_dependency_objects"
      }
    ]
  },
  "projection_profile": {
    "shell_implementation_targets": [
      {
        "backend": "bashly",
        "projection_role": "implementation_target",
        "canonical_target_kind": "config_projection"
      },
      {
        "backend": "argc",
        "projection_role": "implementation_target",
        "canonical_target_kind": "config_projection"
      },
      {
        "backend": "argbash",
        "projection_role": "implementation_target",
        "canonical_target_kind": "config_projection"
      }
    ],
    "python_implementation_targets": [
      {
        "backend": "jsonargparse",
        "projection_role": "implementation_target",
        "canonical_target_kind": "codegen_input"
      }
    ],
    "shell_verification_targets": [
      {
        "backend": "bats",
        "projection_role": "verification_consumer",
        "canonical_target_kind": "other"
      },
      {
        "backend": "shellspec",
        "projection_role": "verification_consumer",
        "canonical_target_kind": "other"
      }
    ],
    "python_verification_targets": [
      {
        "backend": "pytest",
        "projection_role": "verification_consumer",
        "canonical_target_kind": "other"
      }
    ]
  },
  "open_items": [
    "decide whether verification targets warrant a narrower target_kind than other",
    "define a migration boundary for readers and generators consuming shell_cli_role versus cli_role artifacts"
  ],
  "resolved_items": [
    "schema-backed extension constraints have been generalized from shell_cli_role to cli_role",
    "runtime-neutral semantic and projection examples exist"
  ]
}
