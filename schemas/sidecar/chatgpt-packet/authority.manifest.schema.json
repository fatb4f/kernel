{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/sidecar/chatgpt-packet/authority.manifest.schema.json",
  "title": "ChatGPT packet sidecar authority manifest",
  "description": "Sidecar validation contract for the kernel-owned authority manifest.",
  "type": "object",
  "required": [
    "kind",
    "spec_version",
    "sidecar_status",
    "workflow_authority_root",
    "validation_surface_root",
    "template_surface_root",
    "precedence",
    "conflict_resolution",
    "approval_basis_inputs",
    "delegated_surfaces",
    "deprecation_note"
  ],
  "properties": {
    "kind": {
      "const": "chatgpt-sidecar-authority-manifest"
    },
    "spec_version": {
      "type": "string"
    },
    "sidecar_status": {
      "type": "string"
    },
    "workflow_authority_root": {
      "type": "string"
    },
    "validation_surface_root": {
      "type": "string"
    },
    "template_surface_root": {
      "type": "string"
    },
    "precedence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conflict_resolution": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approval_basis_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "delegated_surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "role",
          "status"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "deprecation_note": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
