{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenAI conversation context",
  "description": "Compatibility-only contract for provider conversation context.",
  "type": "object",
  "required": [
    "thread_id",
    "messages"
  ],
  "properties": {
    "thread_id": {
      "type": "string"
    },
    "session_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "content": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
