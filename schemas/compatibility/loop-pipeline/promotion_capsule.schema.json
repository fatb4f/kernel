{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Promotion capsule",
  "description": "Historical compatibility contract for loop-pipeline promotion metadata.",
  "type": "object",
  "required": [
    "packet_id",
    "base_ref",
    "evidence_paths"
  ],
  "properties": {
    "packet_id": {
      "type": "string"
    },
    "base_ref": {
      "type": "string"
    },
    "evidence_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
