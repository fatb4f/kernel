{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "canonical-structure-family.schema.json",
  "title": "Canonical structure family",
  "description": "Derived contract for an authority-safe kernel structure module.",
  "type": "object",
  "required": [
    "kind",
    "id",
    "fragments"
  ],
  "properties": {
    "kind": {
      "const": "kernel-structure-module"
    },
    "id": {
      "type": "string"
    },
    "fragments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "class"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "class": {
            "type": "string",
            "enum": [
              "core",
              "extension",
              "relation",
              "adapter"
            ]
          },
          "source_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "from",
          "to",
          "relation"
        ],
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "relation": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
