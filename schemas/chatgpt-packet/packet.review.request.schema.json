{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/chatgpt-packet/packet.review.request.schema.json",
  "title": "ChatGPT packet review request",
  "description": "Pre-decision review submission artifact.",
  "type": "object",
  "required": [
    "artifact_type",
    "artifact_version",
    "packet_id",
    "workflow_state",
    "review_state",
    "submitted_by",
    "review_scope",
    "requested_outcomes",
    "review_basis_refs",
    "human_action_required",
    "approval_authority",
    "artifact_status"
  ],
  "properties": {
    "artifact_type": {
      "const": "gpt_handoff.packet.review.request"
    },
    "artifact_version": {
      "type": "string"
    },
    "packet_id": {
      "type": "string"
    },
    "workflow_state": {
      "type": "string"
    },
    "review_state": {
      "type": "string"
    },
    "submitted_by": {
      "type": "object"
    },
    "review_scope": {
      "type": "string"
    },
    "requested_outcomes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_basis_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "kernel_trust": {
      "type": "object"
    },
    "human_action_required": {
      "type": "boolean"
    },
    "approval_authority": {
      "type": "boolean"
    },
    "artifact_status": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
