{
  "kind": "chatgpt-sidecar-authority-manifest",
  "spec_version": "0.1.3",
  "sidecar_status": "temporary_shallow_sidecar",
  "workflow_authority_root": "control/scm.pattern",
  "validation_surface_root": "schemas/control/scm.pattern",
  "template_surface_root": "templates",
  "precedence": [
    "control/scm.pattern/authority.manifest.json",
    "control/scm.pattern/**",
    "schemas/control/scm.pattern/**",
    "templates/**",
    "generated/**"
  ],
  "conflict_resolution": [
    "workflow docs define lifecycle and review semantics",
    "schemas define object shape and field validity",
    "templates scaffold only",
    "generated artifacts are instances only",
    "fail closed on control or schema drift"
  ],
  "approval_basis_inputs": [
    "control/scm.pattern/authority.manifest.json",
    "control/trust/root.signers.json",
    "control/trust/delegations/chatgpt.packet-sidecar.json",
    "generated/schemas/chatgpt-pipeline/workflow/chatgpt.packet.pipeline.manifest.json",
    "generated/schemas/chatgpt-pipeline/workflow/chatgpt.execution.policy.json",
    "generated/schemas/chatgpt-pipeline/workflow/chatgpt.validation.manifest.json",
    "generated/schemas/chatgpt-pipeline/workflow/chatgpt.gate.policy.json",
    "generated/schemas/chatgpt-pipeline/workflow/problem_set.schema.json",
    "generated/schemas/chatgpt-pipeline/packet/**"
  ],
  "delegated_surfaces": [
    {
      "path": "control/scm.pattern/**",
      "role": "workflow_authority",
      "status": "normative_for_lifecycle"
    },
    {
      "path": "generated/schemas/chatgpt-pipeline/workflow/**",
      "role": "execution_runtime",
      "status": "normative_for_packet_authoring"
    },
    {
      "path": "generated/schemas/chatgpt-pipeline/packet/**",
      "role": "validation_surface",
      "status": "delegated_validation_only"
    },
    {
      "path": "templates/**",
      "role": "rendering_surface",
      "status": "scaffold_only"
    }
  ],
  "deprecation_note": "This authority surface remains intentionally shallow and removable. The operational packet runtime stays local and realization remains outside the ChatGPT boundary."
}
