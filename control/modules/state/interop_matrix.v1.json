      "transport": "ACP",
      "output": "schema-versioned envelope",
      "classification": "semantic"
    },
    {
      "entity": "marimo_registry",
      "kind": "registry_consumer",
      "surface_id": "state.registry.marimo",
      "wrapper": "registry and hydration lifecycle",
      "adapter_or_interface": "snapshot registration and view derivation",
      "transport": "ACP response consumption",
