      "transport": "local process boundary",
      "output": "repo_state + diff_state",
      "classification": "projection"
    },
    {
      "entity": "sem",
      "kind": "adapter",
      "surface_id": "state.interface.semantic.sem",
      "wrapper": "emit_sem_runtime.py",
      "adapter_or_interface": "semantic enrichment",
