{
  "kind": "kernel.chatgpt_packet_pipeline",
  "version": "0.1.0",
  "status": "active",
  "purpose": "Deterministic ChatGPT packet authoring pipeline from a single problem_set input with local realization outside the model boundary.",
  "entry": {
    "input_contract_ref": "generated/schemas/chatgpt-pipeline/workflow/problem_set.schema.json",
    "authority_manifest_ref": "control/scm.pattern/authority.manifest.json",
    "authority_manifest_schema_ref": "generated/schemas/chatgpt-pipeline/packet/authority.manifest.schema.json"
  },
  "authority": {
    "kernel_root": "kernel",
    "source_priority": [
      "kernel/meta-manifest.yaml",
      "kernel/sources/manifest.yaml",
      "kernel/manifests/contracts.yaml",
      "kernel/manifests/workflows.yaml",
      "kernel/manifests/publication.yaml",
      "kernel/manifests/lineage.yaml",
      "kernel/manifests/glossary.yaml",
      "kernel/manifests/decision-register.yaml"
    ],
    "conflict_rule": "Higher priority wins; unresolved conflicts must be surfaced."
  },
  "generation_order": [
    "normalize problem_set",
    "author packet.definition",
    "bind scm.pattern",
    "emit review.request",
    "emit root.trust.evidence",
    "emit regen.record",
    "emit artifact.manifest"
  ],
  "output_family": {
    "required_artifacts": [
      "generated/packets/<packet_id>/machine/packet.definition.json",
      "generated/packets/<packet_id>/machine/scm.pattern.binding.json",
      "generated/packets/<packet_id>/machine/packet.review.request.json",
      "generated/packets/<packet_id>/machine/root.trust.evidence.json",
      "generated/packets/<packet_id>/machine/regen.record.json",
      "generated/packets/<packet_id>/machine/artifact.manifest.json",
      "generated/packets/<packet_id>/human/packet.definition.md"
    ],
    "conditional_artifacts": [
      "generated/packets/<packet_id>/machine/packet.review.decision.json"
    ],
    "compatibility_artifacts": [
      "generated/packets/<packet_id>/machine/packet.approval.json"
    ]
  },
  "execution_model": {
    "chatgpt_role": "deterministic packet authoring",
    "local_runtime_role": "validation, admission, and realization",
    "cross_boundary_rule": "ChatGPT does not realize work."
  },
  "state_model": {
    "states": [
      "REQUESTED",
      "DEFINITION_DRAFTED",
      "DEFINITION_UNDER_REVIEW",
      "REQUIRES_REAPPROVAL",
      "DEFINITION_APPROVED",
      "REALIZED_VIA_SCM_PATTERN",
      "CLOSED"
    ]
  }
}
