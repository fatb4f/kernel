{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "generated/schemas/chatgpt-pipeline/workflow/problem_set.schema.json",
  "title": "Problem set input",
  "description": "First-class ingress contract for deterministic ChatGPT packet generation.",
  "type": "object",
  "required": [
    "kind",
    "problem_set_id",
    "version",
    "status",
    "identity",
    "objective",
    "scope",
    "constraints",
    "assumptions",
    "requested_outputs",
    "authority_refs",
    "acceptance_criteria"
  ],
  "properties": {
    "kind": {
      "const": "kernel.problem_set"
    },
    "problem_set_id": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "identity": {
      "type": "object",
      "required": [
        "name",
        "title"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "owners": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "objective": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "required": [
        "in_scope",
        "out_of_scope"
      ],
      "properties": {
        "in_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requested_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authority_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "fingerprint": {
      "type": "object",
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "sha256"
          ]
        },
        "value": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "change_control": {
      "type": "object",
      "properties": {
        "normalized_json": {
          "type": "boolean"
        },
        "stale_when": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
