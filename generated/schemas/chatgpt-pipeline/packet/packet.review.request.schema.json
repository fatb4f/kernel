{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "generated/schemas/chatgpt-pipeline/packet/packet.review.request.schema.json",
  "title": "ChatGPT packet review request",
  "description": "Pre-decision review submission artifact.",
  "type": "object",
  "required": [
    "artifact_type",
    "artifact_version",
    "packet_id",
    "workflow_state",
    "review_state",
    "submitted_by",
    "review_scope",
    "requested_outcomes",
    "review_basis_refs",
    "human_action_required",
    "approval_authority",
    "artifact_status"
  ],
  "properties": {
    "artifact_type": {
      "const": "gpt_handoff.packet.review.request"
    },
    "artifact_version": {
      "type": "string"
    },
    "packet_id": {
      "type": "string"
    },
    "workflow_state": {
      "type": "string"
    },
    "review_state": {
      "type": "string"
    },
    "submitted_by": {
      "type": "object",
      "required": ["role"],
      "properties": {
        "role": { "type": "string" }
      },
      "additionalProperties": false
    },
    "review_scope": {
      "type": "string"
    },
    "requested_outcomes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_basis_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "kernel_trust": {
      "type": "object",
      "required": [
        "authority_manifest_ref",
        "authority_manifest_validation_ref",
        "authority_manifest_signature_ref",
        "delegation_ref",
        "root_trust_evidence_ref"
      ],
      "properties": {
        "authority_manifest_ref": { "type": "string" },
        "authority_manifest_validation_ref": { "type": "string" },
        "authority_manifest_signature_ref": { "type": "string" },
        "delegation_ref": { "type": "string" },
        "root_trust_evidence_ref": { "type": "string" }
      },
      "additionalProperties": false
    },
    "human_action_required": {
      "type": "boolean"
    },
    "approval_authority": {
      "type": "boolean"
    },
    "artifact_status": {
      "type": "string"
    }
  },
