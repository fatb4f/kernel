{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "generated/schemas/chatgpt-pipeline/packet/root.trust.evidence.schema.json",
  "title": "Kernel trust evidence",
  "description": "Packet-local trust boundary evidence referencing kernel-owned authority state.",
  "type": "object",
