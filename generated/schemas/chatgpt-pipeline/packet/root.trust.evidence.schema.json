        "root_signers_ref": { "type": "string" },
        "root_delegation_ref": { "type": "string" },
        "authority_manifest_ref": { "type": "string" },
        "authority_manifest_validation_ref": { "type": "string" },
        "authority_manifest_signature_ref": { "type": "string" },
        "pipeline_manifest_ref": { "type": "string" },
        "execution_policy_ref": { "type": "string" },
        "validation_manifest_ref": { "type": "string" },
        "gate_policy_ref": { "type": "string" },
        "problem_set_schema_ref": { "type": "string" }
