    },
    "canonical_refs": {
      "type": "object",
      "required": [
        "root_signers_ref",
        "root_delegation_ref",
        "authority_manifest_ref",
        "authority_manifest_validation_ref",
        "authority_manifest_signature_ref",
        "pipeline_manifest_ref",
        "execution_policy_ref",
        "validation_manifest_ref",
        "gate_policy_ref",
        "problem_set_schema_ref"
