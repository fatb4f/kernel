{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "generated/schemas/chatgpt-pipeline/packet/artifact.manifest.schema.json",
  "title": "Packet artifact manifest",
  "description": "Manifest of required and conditional packet artifacts.",
  "type": "object",
  "required": [
    "artifact_type",
    "artifact_version",
    "packet_id",
    "workflow_state",
    "review_state",
    "required_artifacts",
    "conditional_artifacts"
  ],
  "properties": {
    "artifact_type": {
      "const": "gpt_handoff.artifact.manifest"
    },
    "artifact_version": {
      "type": "string"
    },
    "packet_id": {
      "type": "string"
    },
    "workflow_state": {
      "type": "string"
    },
    "review_state": {
      "type": "string"
    },
    "required_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ref",
          "kind"
        ],
        "properties": {
          "ref": { "type": "string" },
          "kind": { "type": "string" },
          "transitional": { "type": "boolean" },
          "authoritative": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "conditional_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ref",
          "kind",
          "required_when"
        ],
        "properties": {
          "ref": { "type": "string" },
          "kind": { "type": "string" },
          "required_when": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "supporting_inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
